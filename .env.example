# .env.example — committed CONTRACT (no secrets). Copy to .env and fill the blanks.
# Read by app/config.py (pydantic-settings). USE_REAL_*=false runs the keyless stub path.

# --- secrets (leave blank here; fill only in your gitignored .env) ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# --- LLM ---
LLM_PROVIDER=anthropic
LLM_MODEL=claude-sonnet-4-6          # match the model in your .env
USE_REAL_LLM=true                    # false -> deterministic stub (zero-keys, offline)

# --- embeddings ---
EMBED_MODEL=text-embedding-3-small
EMBED_DIM=1536
USE_REAL_EMBED=true                  # false -> hashing/stub embedder (offline)

# --- vector store ---
VECTOR_BACKEND=chroma                # chroma | pgvector
PG_TABLE=embeddings                  # used when VECTOR_BACKEND=pgvector

# --- observability (optional) ---
LANGFUSE_HOST=https://cloud.langfuse.com

# --- cost / safety caps ---
MAX_LLM_CALLS_PER_RUN=25
MAX_LLM_CALLS_PER_SESSION=100
MAX_LLM_TOKENS_PER_RUN=200000
MAX_EMBED_CALLS_PER_RUN=50

# Note: Chroma telemetry is disabled in code (ANONYMIZED_TELEMETRY=False) for offline-first.
# Note: the active policy pack defaults to energy_utilities_us (selected at run).
